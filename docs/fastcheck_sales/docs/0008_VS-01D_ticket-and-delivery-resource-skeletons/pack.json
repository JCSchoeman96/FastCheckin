      "later resources or forbidden boundary modules are created",
      "plaintext token fields are introduced",
      "PII or provider error fields are logged"
    ],
    "green_requires": [
      "mix compile passes",
      "formatting passes",
      "migrations create only the two intended tables",
      "resources compile with AshPostgres",
      "FastCheck.Sales registers the intended resources",
      "required fields, indexes, identities, and relationships exist",
      "TicketIssue.status represents issuance/validity only",
      "DeliveryAttempt is the delivery audit source of truth",
      "no workflow behavior or cross-boundary side effects are added",
      "no plaintext token storage or PII logging is added"
    ]
  },
  "channel_strategy": "multi_channel_whatsapp_first",
