  "policy_requirements": {
    "customer_session": [
      "no broad reads",
      "no direct mutations",
      "no raw payment/delivery/conversation internals"
    ],
    "operator": [
      "support read only",
      "no raw provider payloads",
      "not equivalent to admin"
    ],
    "admin": [
      "scoped read/manage according to accepted tenant/event model"
    ],
    "system": [
      "internal actions and future worker transitions only"
    ]
  },
  "forbidden_actions": [
    "generic update_status",
    "checkout workflows",
    "payment verification workflows",
    "ticket issuing workflows",
    "delivery sending workflows",
    "conversation menu workflows",
    "manual review operations"
  ],
  "red_green_tests": {
    "type": "ash_policy_tests",
    "red_requires_failure_when": [
      "customer_session can broadly read any Sales resource",
      "operator can access raw provider payload fields",
      "operator is authorized as admin",
      "StateTransition can be updated or destroyed",
      "tenant/event cross-scope reads are allowed when tenanting is accepted",
      "workflow or provider boundary code appears in this slice"
    ],
    "green_requires": [
      "all Sales resources compile with policies",
      "policy tests cover system/admin/operator/customer_session",
      "customer_session broad reads are denied",
      "operator raw payload access is denied or unavailable",
      "StateTransition remains append-only",
      "no Redis/Paystack/Meta/ticket/scanner/Admin UI behavior is added"
    ]
  },
  "channel_strategy": "multi_channel_whatsapp_first",
  "primary_production_channel": "whatsapp_first_paid_core",
  "secondary_sales_paths": [
    "admin_assisted_sales",
    "web_checkout_sales",
    "internal_pilot_sales"
  ],
  "performance_impact": "policy-only slice; no hot path runtime behavior added",
