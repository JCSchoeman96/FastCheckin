      "FastCheck.Sales does not register the three VS-01C resources",
      "any required table is missing",
      "required fields are missing",
      "required identities/indexes are missing",
      "CheckoutSession does not belong to Order",
      "PaymentAttempt does not belong to Order",
      "PaymentEvent dedupe indexes are missing",
      "generic update_status exists",
      "later resource modules are created too early",
      "Redis/Paystack/Meta/Ticket/Scanner/Admin code is added",
      "raw provider payloads are logged or exposed in tests"
    ],
    "green_requires": [
      "mix compile passes",
      "formatting passes",
      "migrations create only the three intended tables",
      "resources compile with AshPostgres",
      "FastCheck.Sales registers the intended resources",
      "required fields, indexes, identities, and relationships exist",
      "no workflow behavior or cross-boundary side effects are added",
      "raw provider payloads are persisted only as restricted fields and not logged"
    ]
  },
  "channel_strategy": "multi_channel_whatsapp_first",
