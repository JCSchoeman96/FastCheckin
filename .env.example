# Example FastCheck production environment. Copy to /etc/fastcheck.env or export
# locally before running `mix release`/`bin/petal_blueprint start`.
MIX_ENV=prod
SECRET_KEY_BASE=<generate with mix phx.gen.secret>
ENCRYPTION_KEY=<generate with mix phx.gen.secret; keep this constant across deploys>
MOBILE_JWT_SECRET=<generate with mix phx.gen.secret>
DATABASE_URL=ecto://fastcheck:password@localhost:5432/fastcheck_prod
REDIS_URL=redis://localhost:6379
# DATABASE_POOLING_MODE controls whether the shared Repo talks directly to Postgres
# or through PgBouncer. Valid values: direct, pgbouncer_transaction, pgbouncer_session
DATABASE_POOLING_MODE=direct
# Start with unnamed prepares for PgBouncer transaction pooling unless your
# PgBouncer/Postgrex/Ecto combination is explicitly verified safe otherwise.
# DB_PREPARE_MODE=unnamed
# OBAN_NOTIFIER defaults to pg for pgbouncer_transaction and postgres otherwise.
# Set pg only after verifying notifier/cluster behavior in the deployed topology.
# OBAN_NOTIFIER=pg
# Keep migrations on direct Postgres when DATABASE_URL points at PgBouncer.
# MIGRATION_DATABASE_URL=ecto://fastcheck:password@localhost:5432/fastcheck_prod
DEFAULT_TICKERA_SITE_URL=https://voelgoed.co.za
DOMAIN=your-domain.com
PORT=8080
ENABLE_HTTPS=false
# HTTPS_PORT defaults to 443 when ENABLE_HTTPS=true

# Optional tuning knobs
PHX_SERVER=true
POOL_SIZE=20
ECTO_IPV6=false
# Payment enforcement policy: keep false for strict mode.
# Set true only as a temporary fallback if Tickera omits payment status.
ALLOW_UNKNOWN_PAYMENT_STATUS=false

# TLS configuration. Defaults match Let's Encrypt paths but can be pointed
# elsewhere when using a different certificate authority.
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# Dashboard admin login (defaults: admin / fastcheck)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=fastcheck

# Uncomment to enable distributed clustering via DNS on Fly.io/Kubernetes.
# DNS_CLUSTER_QUERY=_fastcheck._tcp.your-domain.internal
