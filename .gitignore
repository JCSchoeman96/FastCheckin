# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
petal_blueprint-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# Environment files (contain secrets)
.env
.env.local

# Code quality and security tools
/.credo_cache/
/.sobelow/

# Android scanner app local configuration and build artifacts
android/scanner-app/local.properties
android/scanner-app/.gradle/
android/scanner-app/app/build/

# IDE/project files
.idea/
*.iml
.vscode/

# OS/editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
~$*

# Local performance seed outputs
/performance/manifests/*.json
/performance/results/*.log
/performance/results/*.pid

# Dolt database files (added by bd init)
.dolt/
*.db

.beads/.beads-credential-key

.beads/dolt-config.log
# bd worktree
mobile-scan-ingestion-phase1/
