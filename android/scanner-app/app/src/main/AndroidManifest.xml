<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Declares camera is not required for large-screen / ChromeOS Play filtering (lint PermissionImpliesUnsupportedChromeOsHardware). -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name="za.co.voelgoed.fastcheck.app.ScannerApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="FastCheck Scanner"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.FastCheck.Scanner"
        android:usesCleartextTraffic="false">
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
        <activity
            android:name="za.co.voelgoed.fastcheck.app.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
