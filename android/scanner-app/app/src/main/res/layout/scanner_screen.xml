<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/scanner_section_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/scanner_section_title"
        android:textSize="18sp"
        android:textStyle="bold" />

    <include
        android:id="@+id/scanner_permission_view"
        layout="@layout/scanner_permission_view" />

    <androidx.camera.view.PreviewView
        android:id="@+id/scanner_preview"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="12dp"
        android:background="#1A1A1A"
        android:visibility="gone" />

    <TextView
        android:id="@+id/scanner_status_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/scanner_status_ready" />
</LinearLayout>
