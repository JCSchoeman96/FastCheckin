<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sync_section_title"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/sync_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/sync_button_label" />

        <TextView
            android:id="@+id/sync_summary_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/no_sync_yet" />

        <TextView
            android:id="@+id/sync_error_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/no_errors" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/scanner_section_title"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/scanner_permission_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/scanner_permission_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/scanner_permission_unknown" />

        <Button
            android:id="@+id/request_camera_permission_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/request_camera_permission_button_label" />

        <androidx.camera.view.PreviewView
            android:id="@+id/scanner_preview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            android:background="#1A1A1A"
            android:visibility="gone" />

        <TextView
            android:id="@+id/scanner_status_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/scanner_status_ready" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/manual_queue_section_title"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/manual_ticket_code_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/manual_ticket_code_hint"
            android:inputType="text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/manual_direction_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/manual_direction_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/manual_direction_in" />

        <Button
            android:id="@+id/queue_scan_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/queue_scan_button_label" />

        <Button
            android:id="@+id/flush_queue_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/flush_queue_button_label" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/queue_depth_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/manual_queue_depth_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Queued locally: 0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/latest_flush_state_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/manual_upload_state_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Idle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/recent_outcome_summary_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/manual_server_result_hint_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_server_outcomes_yet" />

        <TextView
            android:id="@+id/scan_action_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/manual_queue_ready" />

        <TextView
            android:id="@+id/scan_error_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/no_errors" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/diagnostics_section_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/refresh_diagnostics_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/refresh_label" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/current_event_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/current_event_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_active_event" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/auth_state_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/auth_state_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/logged_out" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/token_expiry_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/token_expiry_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/unknown_value" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/last_sync_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/last_sync_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/never_value" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/attendee_count_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/attendee_count_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/queue_depth_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/queue_depth_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/latest_flush_state_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/latest_flush_state_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/never_value" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/latest_flush_summary_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/latest_flush_summary_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_flush_yet" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/recent_outcome_summary_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recent_outcome_summary_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_recent_outcomes" />
    </LinearLayout>
</ScrollView>
